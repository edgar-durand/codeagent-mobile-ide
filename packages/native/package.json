{
  "name": "@codeam/ide-native",
  "version": "0.1.0",
  "description": "React Native UI surface of @codeam/ide — Monaco-backed file viewer, file explorer, source control, search and (Phase 3) extension runtime. Drops into any Expo / RN app as React components; consumers wire their own backend via the @codeam/ide-core adapter contract.",
  "keywords": [
    "ide",
    "mobile",
    "react-native",
    "expo",
    "vs-code",
    "monaco",
    "file-editor",
    "codeagent"
  ],
  "license": "MIT",
  "author": "Edgar Durand",
  "repository": {
    "type": "git",
    "url": "https://github.com/edgar-durand/codeagent-mobile-ide.git",
    "directory": "packages/native"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist .tsbuildinfo"
  },
  "dependencies": {
    "@codeam/ide-core": "0.1.0"
  },
  "peerDependencies": {
    "@expo/vector-icons": ">=14",
    "react": ">=18",
    "react-native": ">=0.74",
    "react-native-safe-area-context": ">=4",
    "react-native-webview": ">=13"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@types/react": "^19.2.14",
    "react": "^19.2.6",
    "react-native": "^0.85.3",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-webview": "^13.16.1"
  }
}
